# Copy to .env.local

# ── App Check ──
# reCAPTCHA v3 site key registered in Firebase Console → App Check → Web app
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Optional fixed debug token for localhost (Console → App Check → Manage debug tokens)
NEXT_PUBLIC_APPCHECK_DEBUG_TOKEN=

# ── Stripe (online deposits) ──
# Show the "Pay online" option in the booking flow
NEXT_PUBLIC_STRIPE_ENABLED=false
# Secret key (sk_test_… locally). In production this lives in Secret Manager
# via apphosting.yaml, never in a committed file.
STRIPE_SECRET_KEY=
# From `stripe listen --forward-to localhost:3000/api/stripe-webhook` in dev,
# or the dashboard webhook endpoint's signing secret in production.
STRIPE_WEBHOOK_SECRET=
