rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isStr(v, max) {
      return v is string && v.size() <= max;
    }

    // Admin roster — managed only from the Firebase console (or Admin SDK),
    // never from the client. Users may check their own membership.
    match /admins/{uid} {
      allow get: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list, create, update, delete: if false;
    }

    // Site copy (hero, announcement, contact, signature styles).
    match /content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public sees only visible services (queries must filter visible == true).
    match /services/{id} {
      allow read: if resource.data.visible == true || isAdmin();
      allow write: if isAdmin();
    }

    match /faqs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public sees only published reviews (queries must filter status == 'published').
    match /reviews/{id} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }

    match /photos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Slot markers keep availability public without exposing client PII.
    // Doc id is "<date>_<time>" so a create can never double-book: creating
    // an existing id is an update, and public updates are denied.
    match /slots/{slotId} {
      allow read: if true;
      allow create: if isAdmin() || (
        request.resource.data.status == 'booked'
        && slotId == request.resource.data.date + '_' + request.resource.data.time
        && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && request.resource.data.time.matches('^[0-9]{1,2}:[0-9]{2} (AM|PM)$')
      );
      allow update, delete: if isAdmin();
    }

    // Bookings hold client PII: anyone may create (the booking flow),
    // only admins may read or change them.
    match /bookings/{id} {
      allow create: if isAdmin() || (
        isStr(request.resource.data.client, 120)
        && request.resource.data.client.size() > 0
        && isStr(request.resource.data.phone, 40)
        && request.resource.data.phone.size() > 0
        && isStr(request.resource.data.notes, 1000)
        && isStr(request.resource.data.serviceId, 60)
        && isStr(request.resource.data.serviceName, 120)
        && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && request.resource.data.time.matches('^[0-9]{1,2}:[0-9]{2} (AM|PM)$')
        && request.resource.data.status == 'deposit-paid'
      );
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
